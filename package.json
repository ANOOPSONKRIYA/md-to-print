{
  "name": "md-to-print",
  "version": "1.0.0",
  "description": "Markdown to Thermal Receipt Printer (TVS RP3230) – Windows Desktop App",
  "main": "src/main/main.js",
  "author": "MD to Print",
  "license": "MIT",
  "scripts": {
    "dev": "electron .",
    "build:renderer": "node esbuild.config.js",
    "build:python": "cd python-backend && build.bat",
    "dist": "npm run build:renderer && electron-builder",
    "dist:full": "npm run build:renderer && npm run build:python && electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.7.0",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/language-data": "^6.5.0",
    "@codemirror/search": "^6.5.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "codemirror": "^6.0.1",
    "markdown-it": "^14.1.0"
  }
}
